# ============================================================
# LLM Dispatcher — 环境变量配置模板
# 复制为 .env 后修改值（.env 已加入 .gitignore）
# ============================================================

# ── 调度器核心配置 ──────────────────────────────────────────
# 所有以 DISPATCHER_ 开头的变量对应 config 中的 dispatcher 段
# 优先级: 环境变量 > YAML 文件 > 默认值

DISPATCHER_PORT=9090
DISPATCHER_HOST=0.0.0.0
DISPATCHER_LOG_LEVEL=info
# DISPATCHER_UPSTREAM_TIMEOUT=120.0

# ── 后端引擎 API Key（可选）─────────────────────────────────
# 当后端推理引擎需要鉴权时设置（如 LM Studio、vLLM with auth）
# 所有 engine_type="vllm" 的实例转发时会自动携带此 Key
# LM Studio 默认: http://127.0.0.1:12345  sk-lm-xxxxxxxx
BACKEND_API_KEY=sk-lm-xxxxxxxx

# ── Admin API 鉴权（可选）───────────────────────────────────
# 设置后 /admin/* 端点需要 X-API-Key header
# 不设置 = 开发模式，管理端点无鉴权
# ADMIN_API_KEY=your-secret-admin-key

# ── OpenTelemetry 分布式追踪（可选）─────────────────────────
# 不设置 = 控制台输出（开发模式）
# 生产示例: http://jaeger:4318/v1/traces
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# ── LM Studio 本地部署参考 ──────────────────────────────────
# 1. 启动 LM Studio，加载模型（如 qwen3-1.7b）
# 2. LM Studio 默认监听 http://127.0.0.1:12345
# 3. 设置 BACKEND_API_KEY=sk-lm-xxxxxxxx（LM Studio 本地密钥）
# 4. 注册实例:
#    curl -X POST http://localhost:9090/admin/instances \
#      -H "Content-Type: application/json" \
#      -d '{
#        "instance_id":"lm-studio-local",
#        "address":"http://127.0.0.1:12345",
#        "model":"qwen3-1.7b",
#        "engine_type":"vllm"
#      }'
#    注意: LM Studio 使用 OpenAI 兼容格式，engine_type 用 "vllm"
