# ============================================================
# LLM Dispatcher — 环境变量配置模板 (v4)
# 复制为 .env 后修改值（.env 已加入 .gitignore / .dockerignore）
# ============================================================

# ── 调度器核心配置 ──────────────────────────────────────────
DISPATCHER_PORT=9090
DISPATCHER_HOST=0.0.0.0
DISPATCHER_LOG_LEVEL=info

# ── 后端引擎 API Key ────────────────────────────────────────
# v4: 支持 per-instance Key。BACKEND_API_KEY 作为全局 fallback.
# 单后端场景: 只设这一个即可，所有实例自动继承.
BACKEND_API_KEY=sk-lm-xxxxxxxx

# ── 多后端 per-instance Key (v4 新增) ───────────────────────
# 注册实例时传 api_key_env 字段指定读取哪个环境变量.
#   LM_STUDIO_KEY=sk-lm-xxx
#   OPENAI_KEY=sk-openai-xxx
# 注册: {"api_key_env": "LM_STUDIO_KEY"}
# 未传 → 自动 fallback 到 BACKEND_API_KEY

# ── Admin API 鉴权 ──────────────────────────────────────────
# ADMIN_API_KEY=your-secret-admin-key

# ── OpenTelemetry 追踪 ──────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# ═══ 部署拓扑 ═══════════════════════════════════════════════

# ② 单端点多模型 (LM Studio) — 通配符 + 双实例负载均衡
# curl -X POST http://localhost:9090/admin/instances \
#   -d '{"instance_id":"qwen-A","address":"http://127.0.0.1:12345",
#        "model":"*","engine_type":"vllm","capacity_factor":1.5}'
# curl -X POST http://localhost:9090/admin/instances \
#   -d '{"instance_id":"qwen-B","address":"http://127.0.0.1:12345",
#        "model":"*","engine_type":"vllm","capacity_factor":0.8}'

# ① 单端点单模型 (Ollama)
# curl ... -d '{"instance_id":"ollama-1","address":"http://localhost:11434",
#   "model":"llama3","engine_type":"ollama"}'

# ⑥ 远程 API — per-instance Key
# curl ... -d '{"instance_id":"gpt4","address":"https://api.openai.com/v1",
#   "model":"gpt-4o","engine_type":"vllm","api_key_env":"OPENAI_KEY"}'
